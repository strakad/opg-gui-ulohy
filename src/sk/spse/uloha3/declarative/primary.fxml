<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="357.0" prefWidth="600.0"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="sk.spse.uloha3.declarative.Controller">

    <top>
        <HBox prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
            <children>
                <Text fx:id="nadpis" id="nadpis"
                      strokeType="OUTSIDE" strokeWidth="0.0"
                      text="Stredná priemyselná škola elektrotechnická, Prešov"
                      wrappingWidth="599.8">
                    <font>
                        <Font size="25.0" />
                    </font>
                </Text>
            </children>
            <padding>
                <Insets left="30.0" top="25.0" />
            </padding>
        </HBox>
    </top>

    <center>
        <VBox prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER">
            <children>
                <TextArea prefHeight="155.0" prefWidth="397.0"
                          editable="false"
                          text="Vážení rodičia a milí žiaci základných škôl,&#10;&#10;radi by sme Vás privítali v priestoroch našej školy &#10;dňa 10. 02. 2026 (utorok) od 13.00 do 17.00 h na &#10;Dni otvorených dverí, kde by sme Vám chceli &#10;predstaviť naše študijné odbory.">
                    <VBox.margin>
                        <Insets right="10.0" />
                    </VBox.margin>
                </TextArea>
                <Hyperlink text="https://www.spse-po.sk/">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Hyperlink>
            </children>
        </VBox>
    </center>

    <left>
        <!-- id="obrazok" je nutné pre CSS #obrazok selektor -->
        <ImageView fx:id="obrazok" id="obrazok"
                   fitHeight="166.0" fitWidth="161.0"
                   pickOnBounds="true"
                   BorderPane.alignment="CENTER">
            <image>
                <Image url="@spse.png" />
            </image>
            <BorderPane.margin>
                <Insets bottom="50.0" left="5.0" right="10.0" />
            </BorderPane.margin>
        </ImageView>
    </left>

    <bottom>
        <HBox alignment="CENTER_RIGHT" prefHeight="97.0" prefWidth="600.0" BorderPane.alignment="CENTER">
            <children>
                <Button mnemonicParsing="false"
                        onAction="#closeApplication"
                        text="Beriem na vedomie">
                    <HBox.margin>
                        <Insets right="10.0" top="60.0" />
                    </HBox.margin>
                </Button>
            </children>
        </HBox>
    </bottom>
</BorderPane>