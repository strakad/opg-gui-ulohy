<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sk.spse.uloha5.declarative.Controller">

    <!-- NADPIS -->
    <top>
        <HBox alignment="CENTER">
            <Label style="-fx-font-size: 20px; -fx-padding: 15;" text="Zoznam potravín" />
        </HBox>
    </top>

    <!-- TABUĽKA -->
    <center>
        <VBox alignment="CENTER" prefHeight="250.0" prefWidth="600.0" spacing="10.0">
            <padding>
                <Insets bottom="20.0" left="50.0" right="50.0" top="20.0" />
            </padding>

            <TableView fx:id="tabulka" prefHeight="250" prefWidth="600.0">
                <columns>
                    <TableColumn fx:id="id" text="ID" />
                    <TableColumn fx:id="nazovJedal" text="Názov" />
                    <TableColumn fx:id="kalorie" text="Kalórie" />
                    <TableColumn fx:id="cena" text="Cena" />
                </columns>
            <columnResizePolicy>
               <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            </TableView>
        </VBox>
    </center>

    <!-- TLAČIDLÁ -->
    <bottom>
        <HBox alignment="CENTER" prefHeight="75.0" prefWidth="600.0" spacing="30.0">
            <padding>
                <Insets bottom="30.0" left="10.0" right="10.0" top="10.0" />
            </padding>

            <Button alignment="CENTER" text="Pridaj potravinu" />
            <Button alignment="CENTER" onAction="#vymaz" text="Vymaž" />
            <Button alignment="CENTER" onAction="#zatvor" text="Zatvor" />
        </HBox>
    </bottom>

</BorderPane>
